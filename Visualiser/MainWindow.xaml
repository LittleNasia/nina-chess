<Window x:Class="Visualiser.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Nina Chess - Game Data Visualiser"
        Width="960" Height="720"
        MinWidth="740" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#888"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Margin" Value="0,8,0,1"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#222"/>
            <Setter Property="Margin" Value="0,0,0,0"/>
        </Style>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#444"/>
            <Setter Property="Margin" Value="0,14,0,2"/>
        </Style>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Margin" Value="2,0"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MinWidth" Value="32"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" BorderBrush="#DDD" BorderThickness="0,0,0,1" Background="#FAFAFA" Padding="8,5">
            <WrapPanel>
                <Button Content="Open File" Click="OpenFile_Click" Padding="12,4" Margin="0,0,12,0"/>

                <Rectangle Width="1" Fill="#CCC" Margin="0,2,12,2"/>

                <Button Content="&#x23EE;" Click="First_Click" Style="{StaticResource NavButton}" ToolTip="First (Home)"/>
                <Button Content="&#x25C0;" Click="Previous_Click" Style="{StaticResource NavButton}" ToolTip="Previous (Left)"/>
                <TextBlock x:Name="PositionLabel" VerticalAlignment="Center"
                           MinWidth="110" TextAlignment="Center" Margin="4,0" FontSize="13"/>
                <Button Content="&#x25B6;" Click="Next_Click" Style="{StaticResource NavButton}" ToolTip="Next (Right)"/>
                <Button Content="&#x23ED;" Click="Last_Click" Style="{StaticResource NavButton}" ToolTip="Last (End)"/>

                <Rectangle Width="1" Fill="#CCC" Margin="12,2"/>

                <Slider x:Name="PositionSlider" Width="200" Minimum="0" Maximum="0"
                        ValueChanged="Slider_ValueChanged" IsSnapToTickEnabled="True"
                        TickFrequency="1" SmallChange="1" LargeChange="10"
                        VerticalAlignment="Center" Margin="4,0"/>

                <Rectangle Width="1" Fill="#CCC" Margin="12,2"/>

                <TextBlock Text="Overlay:" VerticalAlignment="Center" Margin="4,0,4,0" FontSize="12"/>
                <ComboBox x:Name="OverlayCombo" Width="160"
                          SelectionChanged="Overlay_Changed" VerticalAlignment="Center"/>
            </WrapPanel>
        </Border>

        <!-- Main content -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Board area -->
            <Viewbox Grid.Column="0" Margin="16" Stretch="Uniform">
                <Grid Width="450" Height="430">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="400"/>
                        <ColumnDefinition Width="26"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="400"/>
                        <RowDefinition Height="24"/>
                    </Grid.RowDefinitions>

                    <!-- Rank labels (left) -->
                    <UniformGrid Grid.Column="0" Grid.Row="0" Rows="8" Columns="1">
                        <TextBlock Text="8" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="7" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="6" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="5" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="4" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="2" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="1" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,4,0" FontSize="13" Foreground="#777"/>
                    </UniformGrid>

                    <!-- Board -->
                    <Border Grid.Column="1" Grid.Row="0" BorderBrush="#333" BorderThickness="2">
                        <UniformGrid x:Name="BoardGrid" Rows="8" Columns="8"/>
                    </Border>

                    <!-- File labels (bottom) -->
                    <UniformGrid Grid.Column="1" Grid.Row="1" Rows="1" Columns="8">
                        <TextBlock Text="a" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="b" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="c" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="d" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="e" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="f" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="g" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                        <TextBlock Text="h" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,3,0,0" FontSize="13" Foreground="#777"/>
                    </UniformGrid>
                </Grid>
            </Viewbox>

            <!-- Info panel -->
            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1,0,0,0" Background="White">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,4,14,14">
                        <!-- Position info -->
                        <TextBlock Text="Position Info" Style="{StaticResource SectionHeader}" Margin="0,4,0,2"/>
                        <Separator Margin="0,2,0,0"/>

                        <TextBlock Text="SIDE TO MOVE" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="SideToMoveText" Text="-" Style="{StaticResource InfoValue}"/>

                        <TextBlock Text="SEARCH SCORE" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="ScoreText" Text="-" Style="{StaticResource InfoValue}"/>

                        <TextBlock Text="BEST MOVE" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="BestMoveText" Text="-" Style="{StaticResource InfoValue}"/>

                        <TextBlock Text="MOVE DETAILS" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="MoveDetailsText" Text="-" Style="{StaticResource InfoValue}"/>

                        <TextBlock Text="GAME RESULT" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="ResultText" Text="-" Style="{StaticResource InfoValue}"/>

                        <!-- Board state -->
                        <TextBlock Text="Board State" Style="{StaticResource SectionHeader}"/>
                        <Separator Margin="0,2,0,0"/>

                        <TextBlock Text="CASTLING RIGHTS" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="CastlingText" Text="-" Style="{StaticResource InfoValue}"/>

                        <TextBlock Text="EN PASSANT" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="EnPassantText" Text="-" Style="{StaticResource InfoValue}"/>

                        <TextBlock Text="IN CHECK" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="InCheckText" Text="-" Style="{StaticResource InfoValue}"/>

                        <!-- File info -->
                        <TextBlock Text="File Info" Style="{StaticResource SectionHeader}"/>
                        <Separator Margin="0,2,0,0"/>

                        <TextBlock Text="FILE" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="FileInfoText" Text="-" Style="{StaticResource InfoValue}" TextWrapping="Wrap" FontSize="11"/>

                        <TextBlock Text="TOTAL POSITIONS" Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="TotalPositionsText" Text="-" Style="{StaticResource InfoValue}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </DockPanel>
</Window>
